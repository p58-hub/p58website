{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/projects", "destination": "/index" },
    { "source": "/projects/:slug", "destination": "/index" },
    { "source": "/architecture", "destination": "/index" },
    { "source": "/interiors", "destination": "/index" },
    { "source": "/people", "destination": "/index" },
    { "source": "/agency", "destination": "/index" },
    { "source": "/start-a-project", "destination": "/index" },
    { "source": "/contact", "destination": "/index" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).jsx",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
